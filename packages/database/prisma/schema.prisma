// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Multi-Tenancy (Firmalar)
// -----------------------------------------------------------------------------

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model Tenant {
  id             String         @id @default(uuid())
  name           String         @db.VarChar(255)
  slug           String?        @unique @db.VarChar(100)
  taxNumber      String?        @db.VarChar(50)
  taxOffice      String?        @db.VarChar(100)
  email          String?        @db.VarChar(255)
  phone          String?        @db.VarChar(20)
  address        String?        @db.Text
  city           String?        @db.VarChar(100)
  state          String?        @db.VarChar(100)
  zipCode        String?        @db.VarChar(20)
  country        String?        @default("Turkey") @db.VarChar(100)
  logoUrl        String?        @db.Text
  slogan         String?        @db.VarChar(255) // Eklendi
  website        String?        @db.VarChar(255)
  status         TenantStatus   @default(ACTIVE)
  subscriptionId String?        @unique 
  settings       Json?          @default("{}") // Firma özel ayarları
  
  users           User[]
  customers       Customer[]
  vehicles        Vehicle[]
  mechanics       Mechanic[]
  partCategories  PartCategory[]
  parts           Part[]
  serviceOrders   ServiceOrder[]
  serviceItems    ServiceItem[]
  invoices        Invoice[]
  payments        Payment[]
  appointments    Appointment[]
  suppliers       Supplier[]
  stockMovements  StockMovement[]
  quotes          Quote[]
  notifications   Notification[]
  loyaltyTransactions LoyaltyTransaction[]
  documents       Document[]
  inspectionForms InspectionForm[]
  commissionRules CommissionRule[]
  workLogs        WorkLog[]
  
  notificationProviders NotificationProvider[]
  
  systemNotifications SystemNotification[]
  auditLogs           AuditLog[]
  pushSubscriptions   PushSubscription[]
  locations           Location[]
  messages            Message[]
  maintenancePlans    MaintenancePlan[]
  serviceRatings      ServiceRating[]
  accountingIntegration AccountingIntegration?
  purchaseOrders      PurchaseOrder[]
  stockCounts         StockCount[]
  stockTransfers      StockTransfer[]
  invoiceItems        InvoiceItem[]
  checkPayments       CheckPayment[]
  paymentAttempts     PaymentAttempt[]
  parasutSyncLogs     ParasutSyncLog[]
  invoiceSequences    InvoiceSequence[]
  notificationTemplates          NotificationTemplate[]
  customerNotificationPreferences CustomerNotificationPreference[]
  bulkNotificationCampaigns      BulkNotificationCampaign[]
  kvkkConsents                   KvkkConsent[]
  dataSubjectRequests            DataSubjectRequest[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
}

// -----------------------------------------------------------------------------
// Abonelikler
// -----------------------------------------------------------------------------

// Abonelik durumu
enum SubscriptionStatus {
	TRIAL
	ACTIVE
	PAST_DUE
	CANCELLED
	EXPIRED
}

model SubscriptionPlan {
	id            String   @id @default(uuid())
	name          String   @db.VarChar(100)
	slug          String   @unique @db.VarChar(50)
	description   String?  @db.Text
	priceMonthly  Float
	priceYearly   Float?
	currency      String   @default("TRY") @db.VarChar(3)
	trialDays     Int      @default(14)
	features      Json     @default("{}")
	limits        Json     @default("{}")
	isActive      Boolean  @default(true)
	sortOrder     Int      @default(0)
	
	subscriptions Subscription[]
  
	createdAt     DateTime @default(now())
	updatedAt     DateTime @updatedAt
}

model Subscription {
	id                   String             @id @default(uuid())
	tenantId             String             @unique
	planId               String
	status               SubscriptionStatus @default(TRIAL)
	startDate            DateTime           @db.Date
	currentPeriodStart   DateTime?          @db.Date
	currentPeriodEnd     DateTime?          @db.Date
	cancelAtPeriodEnd    Boolean            @default(false)
	cancelledAt          DateTime?
	cancellationReason   String?            @db.Text
	stripeSubscriptionId String?            @db.VarChar(255)
	metadata             Json?              @default("{}")
	
	plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])
	
	createdAt            DateTime           @default(now())
	updatedAt            DateTime           @updatedAt
}

// Pricing karşılaştırma tablosu satırları
model PlanFeature {
  id                String   @id @default(uuid())
  category          String   @db.VarChar(100)   // "Kullanıcı & Erişim", "Müşteri & Servis", "Finans & Raporlama"
  featureName       String   @db.VarChar(255)   // "Kullanıcı Sayısı", "Yetkilendirme" vb.
  starterValue      String   @db.VarChar(255)   // "1 Kullanıcı", "check", "close", "10MB Sınır"
  professionalValue String   @db.VarChar(255)   // "5 Kullanıcı", "check", "Sınırsız"
  enterpriseValue   String   @db.VarChar(255)   // "Sınırsız", "check", "Dahil"
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Auth.js (NextAuth) Gerekli Modelleri ve Kullanıcı Yapısı
// -----------------------------------------------------------------------------

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  MECHANIC
  RECEPTIONIST
  ACCOUNTANT
}

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(TENANT_ADMIN)
  
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  mechanic      Mechanic?

  isActive      Boolean   @default(true)
  hasTwoFactor  Boolean   @default(false)
  twoFactorSecret      String?   @db.VarChar(255)
  twoFactorBackupCodes String[]
  lastLoginAt   DateTime?

  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
  pushSubscriptions PushSubscription[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// -----------------------------------------------------------------------------
// Faz 4: Müşteri ve Araç Yönetimi (Customer & Vehicle)
// -----------------------------------------------------------------------------

enum CustomerType {
  INDIVIDUAL
  CORPORATE
}

model Customer {
  id              String       @id @default(uuid())
  tenantId        String
  type            CustomerType
  firstName       String?      @db.VarChar(100) // Bireysel için
  lastName        String?      @db.VarChar(100) // Bireysel için
  companyName     String?      @db.VarChar(255) // Kurumsal için
  contactPerson   String?      @db.VarChar(255) // Kurumsal için yetkili
  email           String?      @db.VarChar(255)
  phone           String       @db.VarChar(50)
  secondaryPhone  String?      @db.VarChar(50)
  taxOffice       String?      @db.VarChar(100)
  taxNumber       String?      @db.VarChar(50)
  address         String?      @db.Text
  city            String?      @db.VarChar(100)
  district        String?      @db.VarChar(100)
  notes           String?      @db.Text
  balance         Decimal      @default(0) @db.Decimal(15, 2)
  isBlacklisted   Boolean      @default(false)
  rewardPoints    Int          @default(0)
  membershipTier  String       @default("STANDARD") @db.VarChar(50)
  profileImageUrl String?      @db.Text // Müşteri profil fotoğrafı

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  vehicles        Vehicle[]
  serviceOrders   ServiceOrder[]
  invoices        Invoice[]
  payments        Payment[]
  appointments    Appointment[]
  quotes          Quote[]
  notifications   Notification[]
  loyaltyTransactions LoyaltyTransaction[]
  sentMessages    Message[]    @relation("CustomerSentMessages")
  serviceRatings  ServiceRating[]
  notificationPreference CustomerNotificationPreference?
  kvkkConsents           KvkkConsent[]
  dataSubjectRequests    DataSubjectRequest[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([phone])
}

model Vehicle {
  id                String    @id @default(uuid())
  tenantId          String
  customerId        String
  plate             String    @db.VarChar(20)
  brand             String    @db.VarChar(100) // Marka
  model             String    @db.VarChar(100)
  year              Int?
  chassisNo         String?   @db.VarChar(50)  // VIN
  engineNo          String?   @db.VarChar(50)
  color             String?   @db.VarChar(50)
  engineType        String?   @db.VarChar(50)  // Benzin, Dizel, vs.
  transmission      String?   @db.VarChar(50)  // Manuel, Otomatik
  fuelType          String?   @db.VarChar(50)
  mileage           Int       @default(0)      // Kilometre
  driverName        String?   @db.VarChar(255) // Şoför adı
  driverPhone       String?   @db.VarChar(50)
  insuranceCompany  String?   @db.VarChar(255)
  policyNumber      String?   @db.VarChar(100)
  registrationDate  DateTime? @db.Date
  notes             String?   @db.Text
  imageUrl          String?   @db.Text   // Araç fotoğrafı (S3 URL)
  nextMaintenanceMileage Int?
  nextMaintenanceDate    DateTime? @db.Date

  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  customer          Customer  @relation(fields: [customerId], references: [id])
  serviceOrders     ServiceOrder[]
  appointments      Appointment[]
  quotes            Quote[]
  documents         Document[]
  maintenancePlans  MaintenancePlan[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@unique([plate, tenantId])
  @@index([tenantId])
  @@index([customerId])
  @@index([plate])
}

// -----------------------------------------------------------------------------
// Faz 5: Ustalar ve Stok (Temel)
// -----------------------------------------------------------------------------

model Mechanic {
  id              String    @id @default(uuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Opsiyonel kullanıcı girişi bağlantısı
  userId          String?   @unique
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Temel Bilgiler
  firstName       String    @db.VarChar(100)
  lastName        String    @db.VarChar(100)
  phone           String?   @db.VarChar(50)
  email           String?   @db.VarChar(255)
  
  specialties     String[]  // "Motor", "Elektrik" vb. (String array Prisma'da postgresql desteği)
  experienceYears Int?
  hourlyRate      Decimal?  @db.Decimal(15, 2)
  isActive        Boolean   @default(true)
  
  serviceOrders   ServiceOrder[]
  serviceItems    ServiceItem[]
  commissionRules CommissionRule[]
  workLogs        WorkLog[]
  inspectionForms InspectionForm[]

  // Mobile uygulama alanları
  avatarUrl       String?   @db.Text
  shiftStart      String?   @db.VarChar(5)   // "08:00"
  shiftEnd        String?   @db.VarChar(5)   // "18:00"
  workDays        String[]                   // ["MON","TUE","WED","THU","FRI"]
  dailyTarget     Int?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
}

model PartCategory {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String    @db.VarChar(255)
  description String?   @db.Text
  isActive    Boolean   @default(true)
  
  parts       Part[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([name, tenantId])
  @@index([tenantId])
}

model Part {
  id             String        @id @default(uuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  categoryId     String
  category       PartCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  
  partNumber     String        @db.VarChar(100) // Parça Kodu / Barkodu
  name           String        @db.VarChar(255)
  description    String?       @db.Text
  
  brand          String?       @db.VarChar(100)
  unit           String        @default("adet") @db.VarChar(50)
  
  purchasePrice  Decimal       @db.Decimal(15, 2)
  sellingPrice   Decimal       @db.Decimal(15, 2)
  taxRate        Decimal       @default(20) @db.Decimal(5, 2) // KDV
  
  minStockLevel  Int           @default(0)
  currentStock   Int           @default(0)
  location       String?       @db.VarChar(100)
  
  supplierName   String?       @db.VarChar(255)
  
  isActive       Boolean       @default(true)
  
  // Lokasyon (Şube)
  locationId     String?
  branch         Location?     @relation("PartLocation", fields: [locationId], references: [id], onDelete: SetNull)
  
  serviceItems        ServiceItem[]
  stockMovements      StockMovement[]
  quoteItems          QuoteItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  stockCountItems     StockCountItem[]
  stockTransferItems  StockTransferItem[]
  
  supplierId     String?
  supplier       Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  
  @@unique([partNumber, tenantId])
  @@index([tenantId])
  @@index([categoryId])
}

// -----------------------------------------------------------------------------
// Faz 6: Servis İşlemleri (İş Emirleri & Kalemleri)
// -----------------------------------------------------------------------------

enum ServiceOrderStatus {
  PENDING           // Araç geldi, işlem başlamadı
  IN_PROGRESS       // Tamir/Bakım yapılıyor
  WAITING_APPROVAL  // Müşteriden fiyat/işlem onayı bekleniyor
  COMPLETED         // İşlem bitti, teslime hazır / faturalandı
  CANCELLED         // İptal edildi
}

enum ServiceItemType {
  PART      // Yedek Parça
  LABOR     // İşçilik
  OTHER     // Harici / Diğer masraflar
}

model ServiceOrder {
  id                    String              @id @default(uuid())
  tenantId              String
  tenant                Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  orderNumber           Int                 @default(autoincrement()) // Benzersiz sipariş no (Gerekirse tenant özel no mantığı backendte yapılır)
  status                ServiceOrderStatus  @default(PENDING)
  serviceBay            String?             @db.VarChar(50)
  completionPercentage  Int                 @default(0)
  isUrgent              Boolean             @default(false)
  
  customerId            String
  customer              Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  
  vehicleId             String
  vehicle               Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  
  // Arıza / Şikayet Detayları
  receptionDate         DateTime            @default(now())
  promisedDeliveryDate  DateTime?
  actualDeliveryDate    DateTime?
  
  complaintDescription  String              @db.Text
  inspectionNotes       String?             @db.Text
  internalNotes         String?             @db.Text
  
  // Görevli Usta
  assignedMechanicId    String?
  assignedMechanic      Mechanic?           @relation(fields: [assignedMechanicId], references: [id], onDelete: SetNull)
  
  // Lokasyon
  locationId            String?
  location              Location?           @relation(fields: [locationId], references: [id], onDelete: SetNull)
  
  // Müşteri Onay Token
  approvalToken         String?             @unique @db.VarChar(255)
  approvalTokenExpiry   DateTime?

  // Finansal Matematik
  estimatedCost         Decimal?            @db.Decimal(15,2)
  subTotal              Decimal             @default(0) @db.Decimal(15,2) // Vergi öncesi Parça + İşçilik
  discountAmount        Decimal             @default(0) @db.Decimal(15,2)
  taxAmount             Decimal             @default(0) @db.Decimal(15,2) // Hesaplanan KDV (Toplam)
  totalAmount           Decimal             @default(0) @db.Decimal(15,2) // KDV Dahil Genel Toplam
  
  items                 ServiceItem[]
  invoices              Invoice[]
  payments              Payment[]
  documents             Document[]
  inspectionForms       InspectionForm[]
  workLogs              WorkLog[]
  loyaltyTransactions   LoyaltyTransaction[]
  messages              Message[]
  serviceRating         ServiceRating?
  stockMovements        StockMovement[]
  
  // Kalite Kontrol
  qualityCheckNotes     String?             @db.Text
  qualityCheckedAt      DateTime?
  qualityCheckedBy      String?             @db.VarChar(255)

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?

  @@index([tenantId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
  @@index([receptionDate])
}

model ServiceItem {
  id                 String           @id @default(uuid())
  tenantId           String
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  serviceOrderId     String
  serviceOrder       ServiceOrder     @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  
  itemType           ServiceItemType
  name               String           @db.VarChar(255) // Manuel girilen veya Stok/İşçilikten gelen ad
  description        String?          @db.Text
  
  // Linkler
  partId             String?
  part               Part?            @relation(fields: [partId], references: [id], onDelete: SetNull)
  
  mechanicId         String?          // Bu satırdaki işçiliği yapan usta (labor ise)
  mechanic           Mechanic?        @relation(fields: [mechanicId], references: [id], onDelete: SetNull)
  
  // Fiyat Hesaplama
  quantity           Decimal          @default(1) @db.Decimal(10,2) // Miktar veya Saat
  unitPrice          Decimal          @db.Decimal(15,2) // Birim Fiyat (KDV Hariç)
  taxRate            Decimal          @default(20) @db.Decimal(5,2) // KDV Oranı
  discount           Decimal          @default(0) @db.Decimal(15,2) // Satır İndirimi
  
  subTotal           Decimal          @db.Decimal(15,2) // (Quantity * unitPrice) - discount
  taxAmount          Decimal          @db.Decimal(15,2) // subTotal * taxRate / 100
  totalPrice         Decimal          @db.Decimal(15,2) // subTotal + taxAmount
  
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([tenantId])
  @@index([serviceOrderId])
  @@index([itemType])
}

// -----------------------------------------------------------------------------
// Faz 7: Finans ve Faturalaştırma (Kasa & Ödemeler)
// -----------------------------------------------------------------------------

enum InvoiceType {
  SALES       // Müşteriye Kesilen Fatura / Borçlandırma
  PURCHASE    // Toptancıdan Alınan Fatura / Gider
}

enum InvoiceStatus {
  DRAFT       // Taslak
  SENT        // Gönderildi / Kesildi (Müşteri Borçlandırıldı)
  PAID        // Ödendi
  CANCELLED   // İptal
}

model Invoice {
  id                String            @id @default(uuid())
  tenantId          String
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  invoiceNumber     String?           @db.VarChar(50) // Örn: INV-2023-0001
  type              InvoiceType       @default(SALES)
  status            InvoiceStatus     @default(DRAFT)
  
  customerId        String?
  customer          Customer?          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  
  supplierId        String?
  supplier          Supplier?          @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  
  stockMovements    StockMovement[]
  
  serviceOrderId    String?
  serviceOrder      ServiceOrder?     @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  
  issueDate         DateTime          @default(now())
  dueDate           DateTime?
  
  subTotal          Decimal           @default(0) @db.Decimal(15,2)
  discountAmount    Decimal           @default(0) @db.Decimal(15,2)
  taxAmount         Decimal           @default(0) @db.Decimal(15,2)
  totalAmount       Decimal           @default(0) @db.Decimal(15,2)
  
  paidAmount        Decimal           @default(0) @db.Decimal(15,2)
  
  notes             String?           @db.Text
  
  externalId        String?           @db.VarChar(255) // Örn: Paraşüt Fatura ID
  pdfUrl            String?           @db.Text
  
  payments          Payment[]
  
  // e-Fatura alanları
  items              InvoiceItem[]
  paymentAttempts    PaymentAttempt[]
  parasutSyncLogs    ParasutSyncLog[]
  eInvoiceStatus     EInvoiceStatus?
  eInvoiceUUID       String?           @db.VarChar(100)
  eInvoiceETTN       String?           @db.VarChar(100)
  eInvoiceXmlUrl     String?           @db.Text
  eInvoiceErrorMessage String?         @db.Text
  eInvoiceType       EInvoiceDocType?
  eInvoiceSentAt     DateTime?

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  @@index([tenantId])
  @@index([customerId])
  @@index([serviceOrderId])
  @@index([status])
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  BANK_TRANSFER
  IYZICO
  PAYTR
  CHECK
  PROMISSORY_NOTE
}

enum PaymentType {
  INCOMING    // Tahsilat (Giren Para)
  OUTGOING    // Ödeme (Çıkan Para)
}

model Payment {
  id                String            @id @default(uuid())
  tenantId          String
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  customerId        String?
  customer          Customer?          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  
  supplierId        String?
  supplier          Supplier?          @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  
  invoiceId         String?
  invoice           Invoice?          @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  
  serviceOrderId    String?
  serviceOrder      ServiceOrder?     @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  
  amount            Decimal           @db.Decimal(15,2)
  paymentMethod     PaymentMethod
  paymentType       PaymentType       @default(INCOMING)
  paymentDate       DateTime          @default(now())
  
  notes             String?           @db.Text
  
  // Yeni alanlar
  checkPayment      CheckPayment?
  parasutSyncLogs   ParasutSyncLog[]
  providerPaymentId String?           @db.VarChar(255)

  createdAt         DateTime          @default(now())

  @@index([tenantId])
  @@index([customerId])
  @@index([invoiceId])
  @@index([serviceOrderId])
  @@index([paymentDate])
}

// -----------------------------------------------------------------------------
// Faz 9: Randevular (Appointments)
// -----------------------------------------------------------------------------

enum AppointmentStatus {
  PENDING      // Onay Bekliyor / Yeni
  CONFIRMED    // Onaylandı
  COMPLETED    // Tamamlandı (Servis fişine döndü)
  CANCELLED    // İptal
  NO_SHOW      // Gelmedi
}

model Appointment {
  id              String            @id @default(uuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  customerId      String
  customer        Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  
  vehicleId       String?           // Serbest araç seçimi için opsiyonel
  vehicle         Vehicle?          @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  
  appointmentDate DateTime          @db.Date
  appointmentTime String            @db.VarChar(5) // Örn: "09:30"
  
  type            String?           @db.VarChar(100)
  status          AppointmentStatus @default(PENDING)
  notes           String?           @db.Text
  estimatedCostMin  Decimal?        @db.Decimal(15, 2)
  estimatedCostMax  Decimal?        @db.Decimal(15, 2)
  
  // Lokasyon
  locationId      String?
  location        Location?         @relation(fields: [locationId], references: [id], onDelete: SetNull)
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([appointmentDate])
}

// -----------------------------------------------------------------------------
// Faz 11: Tedarikçiler ve Stok Hareketleri (Suppliers & Stock Movements)
// -----------------------------------------------------------------------------

model Supplier {
  id              String       @id @default(uuid())
  tenantId        String
  name            String       @db.VarChar(255)
  contactPerson   String?      @db.VarChar(255)
  email           String?      @db.VarChar(255)
  phone           String       @db.VarChar(50)
  taxOffice       String?      @db.VarChar(100)
  taxNumber       String?      @db.VarChar(50)
  address         String?      @db.Text
  balance         Decimal      @default(0) @db.Decimal(15, 2)
  notes           String?      @db.Text

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  parts           Part[]
  invoices        Invoice[]
  payments        Payment[]
  purchaseOrders  PurchaseOrder[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
}

// -----------------------------------------------------------------------------
// Stok Yönetimi: Satın Alma Siparişleri (Purchase Orders)
// -----------------------------------------------------------------------------

model PurchaseOrder {
  id              String               @id @default(uuid())
  tenantId        String
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  poNumber        String               @db.VarChar(50)
  supplierId      String
  supplier        Supplier             @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  status          PurchaseOrderStatus  @default(DRAFT)
  expectedDate    DateTime?            @db.Date
  notes           String?              @db.Text
  subTotal        Decimal              @default(0) @db.Decimal(15, 2)
  taxAmount       Decimal              @default(0) @db.Decimal(15, 2)
  totalAmount     Decimal              @default(0) @db.Decimal(15, 2)
  items           PurchaseOrderItem[]
  stockMovements  StockMovement[]
  createdById     String?
  sentAt          DateTime?
  receivedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?

  @@unique([poNumber, tenantId])
  @@index([tenantId])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  partId           String
  part             Part          @relation(fields: [partId], references: [id], onDelete: Restrict)
  quantity         Decimal       @db.Decimal(15, 2)
  unitPrice        Decimal       @db.Decimal(15, 2)
  taxRate          Decimal       @default(20) @db.Decimal(5, 2)
  receivedQuantity Decimal       @default(0) @db.Decimal(15, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([purchaseOrderId])
  @@index([partId])
}

// -----------------------------------------------------------------------------
// Stok Yönetimi: Stok Sayım Modülü (Stock Count)
// -----------------------------------------------------------------------------

model StockCount {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  locationId  String?
  location    Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  status      StockCountStatus @default(DRAFT)
  notes       String?          @db.Text
  startedAt   DateTime         @default(now())
  completedAt DateTime?
  items       StockCountItem[]
  stockMovements StockMovement[]
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([tenantId])
  @@index([locationId])
  @@index([status])
}

model StockCountItem {
  id             String     @id @default(uuid())
  stockCountId   String
  stockCount     StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  partId         String
  part           Part       @relation(fields: [partId], references: [id], onDelete: Restrict)
  systemQuantity Int
  actualQuantity Int?
  difference     Int?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([stockCountId, partId])
  @@index([stockCountId])
  @@index([partId])
}

// -----------------------------------------------------------------------------
// Stok Yönetimi: Lokasyon Transferleri (Stock Transfer)
// -----------------------------------------------------------------------------

model StockTransfer {
  id               String              @id @default(uuid())
  tenantId         String
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromLocationId   String
  fromLocation     Location            @relation("TransferFrom", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocationId     String
  toLocation       Location            @relation("TransferTo", fields: [toLocationId], references: [id], onDelete: Restrict)
  status           StockTransferStatus @default(PENDING)
  notes            String?             @db.Text
  rejectionReason  String?             @db.Text
  requestedById    String?
  approvedById     String?
  requestedAt      DateTime            @default(now())
  approvedAt       DateTime?
  completedAt      DateTime?
  items            StockTransferItem[]
  stockMovements   StockMovement[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([tenantId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
}

model StockTransferItem {
  id              String        @id @default(uuid())
  stockTransferId String
  stockTransfer   StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  partId          String
  part            Part          @relation(fields: [partId], references: [id], onDelete: Restrict)
  quantity        Decimal       @db.Decimal(15, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([stockTransferId])
  @@index([partId])
}

enum StockMovementType {
  IN      // Alım, İade (Giriş)
  OUT     // Satış, Sarf (Çıkış)
  ADJUST  // Sayım Farkı, Düzeltme
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum StockCountStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum StockTransferStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model StockMovement {
  id            String            @id @default(uuid())
  tenantId      String
  partId        String
  quantity      Decimal           @db.Decimal(15,2)
  type          StockMovementType
  reason        String?           @db.Text // "Alım Faturası: INV-001", "Servis: #123"
  
  invoiceId     String?
  invoice       Invoice?          @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  serviceOrderId String?
  serviceOrder   ServiceOrder?    @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)

  serviceItemId  String?          // Hangi servis kaleminden kaynaklandığı (izleme amaçlı)

  purchaseOrderId  String?
  purchaseOrder    PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  stockCountId     String?
  stockCount       StockCount?    @relation(fields: [stockCountId], references: [id], onDelete: SetNull)
  stockTransferId  String?
  stockTransfer    StockTransfer? @relation(fields: [stockTransferId], references: [id], onDelete: SetNull)
  locationId       String?
  location         Location?      @relation("MovementLocation", fields: [locationId], references: [id], onDelete: SetNull)

  createdAt     DateTime          @default(now())
  
  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  part          Part              @relation(fields: [partId], references: [id])

  @@index([tenantId])
  @@index([partId])
}

// -----------------------------------------------------------------------------
// Faz 12: Super Admin / Sistem Yönetimi Modelleri
// -----------------------------------------------------------------------------

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique @db.VarChar(100)
  value       Json     @default("{}")
  description String?  @db.Text
  updatedAt   DateTime @updatedAt
  updatedBy   String?  // Değişikliği yapan super_admin User ID'si

  @@index([key])
}

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

model SystemNotification {
  id        String               @id @default(uuid())
  category  String               @db.VarChar(50) // Örn: SECURITY, BILLING, SYSTEM
  title     String               @db.VarChar(255)
  message   String               @db.Text
  severity  NotificationSeverity @default(INFO)
  isRead    Boolean              @default(false)
  link      String?              @db.VarChar(255)

  // Opsiyonel tenant bazlı (null ise tüm super-admin bildirimleri)
  tenantId  String?
  tenant    Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  createdAt DateTime             @default(now())

  @@index([tenantId])
  @@index([isRead])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  level     String   @db.VarChar(20) // INFO, WARN, ERROR
  module    String   @db.VarChar(100) // Örn: API-GATEWAY, AUTH-SERVICE
  message   String   @db.Text
  traceId   String?  @db.VarChar(100)
  
  // Opsiyonel tenant bağlantısı
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // Olayı gerçekleştiren kullanıcı
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([level])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Yeni Özellikler: Teklif Sistemi
// -----------------------------------------------------------------------------

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quote {
  id              String      @id @default(uuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicleId       String?
  vehicle         Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  quoteNumber     Int         @default(autoincrement())
  status          QuoteStatus @default(DRAFT)
  validUntil      DateTime?
  subTotal        Decimal     @default(0) @db.Decimal(15,2)
  discountAmount  Decimal     @default(0) @db.Decimal(15,2)
  taxAmount       Decimal     @default(0) @db.Decimal(15,2)
  totalAmount     Decimal     @default(0) @db.Decimal(15,2)
  notes           String?     @db.Text
  rejectionReason String?     @db.Text
  items           QuoteItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([customerId])
  @@index([status])
}

model QuoteItem {
  id          String          @id @default(uuid())
  quoteId     String
  quote       Quote           @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  itemType    ServiceItemType
  name        String          @db.VarChar(255)
  description String?         @db.Text
  partId      String?
  part        Part?           @relation(fields: [partId], references: [id], onDelete: SetNull)
  quantity    Decimal         @default(1) @db.Decimal(10,2)
  unitPrice   Decimal         @db.Decimal(15,2)
  taxRate     Decimal         @default(20) @db.Decimal(5,2)
  discount    Decimal         @default(0) @db.Decimal(15,2)
  subTotal    Decimal         @db.Decimal(15,2)
  taxAmount   Decimal         @db.Decimal(15,2)
  totalPrice  Decimal         @db.Decimal(15,2)
  createdAt   DateTime        @default(now())

  @@index([quoteId])
}

// -----------------------------------------------------------------------------
// Yeni Özellikler: Bildirim Sistemi
// -----------------------------------------------------------------------------

enum NotificationType {
  SMS
  EMAIL
  IN_APP
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
  DELIVERED
  READ
}

model Notification {
  id         String             @id @default(uuid())
  tenantId   String
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  type       NotificationType
  channel    String             @db.VarChar(50)
  recipient  String             @db.VarChar(255)
  subject    String?            @db.VarChar(255)
  body       String             @db.Text
  status     NotificationStatus @default(PENDING)
  sentAt     DateTime?
  metadata   Json?              @default("{}")
  retryCount Int                @default(0)
  createdAt  DateTime           @default(now())

  // WhatsApp / Bildirim sistemi yeni alanları
  notificationTemplateId String?
  notificationTemplate   NotificationTemplate? @relation(fields: [notificationTemplateId], references: [id], onDelete: SetNull)
  reminderType           String?               @db.VarChar(50)
  appointmentId          String?               @db.VarChar(255)
  bulkCampaignId         String?
  bulkCampaign           BulkNotificationCampaign? @relation(fields: [bulkCampaignId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([customerId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// Yeni Özellikler: Sadakat Programı
// -----------------------------------------------------------------------------

enum LoyaltyTransactionType {
  EARN
  REDEEM
}

model LoyaltyTransaction {
  id             String                 @id @default(uuid())
  tenantId       String
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId     String
  customer       Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type           LoyaltyTransactionType
  points         Int
  description    String?                @db.Text
  serviceOrderId String?
  serviceOrder   ServiceOrder?          @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  createdAt      DateTime               @default(now())

  @@index([tenantId])
  @@index([customerId])
}

// -----------------------------------------------------------------------------
// Yeni Özellikler: Doküman Yönetimi
// -----------------------------------------------------------------------------

model Document {
  id             String        @id @default(uuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceOrderId String?
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  vehicleId      String?
  vehicle        Vehicle?      @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  fileName       String        @db.VarChar(255)
  fileUrl        String        @db.Text
  fileKey        String        @db.VarChar(500)
  fileType       String        @db.VarChar(100)
  fileSize       Int
  uploadedBy     String        @db.VarChar(255)
  createdAt      DateTime      @default(now())

  @@index([tenantId])
  @@index([serviceOrderId])
  @@index([vehicleId])
}

// -----------------------------------------------------------------------------
// Yeni Özellikler: Muayene Formu
// -----------------------------------------------------------------------------

model InspectionForm {
  id             String       @id @default(uuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  mechanicId     String?
  mechanic       Mechanic?    @relation(fields: [mechanicId], references: [id], onDelete: SetNull)
  formData       Json         @default("{}")
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([tenantId])
  @@index([serviceOrderId])
}

// -----------------------------------------------------------------------------
// Yeni Özellikler: Komisyon Kuralları ve İş Günlüğü
// -----------------------------------------------------------------------------

enum CommissionRuleType {
  PERCENTAGE
  FIXED
}

model CommissionRule {
  id         String             @id @default(uuid())
  tenantId   String
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mechanicId String?
  mechanic   Mechanic?          @relation(fields: [mechanicId], references: [id], onDelete: SetNull)
  ruleType   CommissionRuleType
  value      Decimal            @db.Decimal(10,4)
  minAmount  Decimal?           @db.Decimal(15,2)
  maxAmount  Decimal?           @db.Decimal(15,2)
  isActive   Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([tenantId])
  @@index([mechanicId])
}

model WorkLog {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mechanicId      String
  mechanic        Mechanic      @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
  serviceOrderId  String?
  serviceOrder    ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())

  @@index([tenantId])
  @@index([mechanicId])
  @@index([serviceOrderId])
}


// -----------------------------------------------------------------------------
// Web Push Bildirimleri
// -----------------------------------------------------------------------------

model PushSubscription {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([tenantId])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// 2FA (TOTP)
// -----------------------------------------------------------------------------
// User modeline twoFactorSecret ve twoFactorBackupCodes alanları eklendi
// (migration ile User tablosuna ALTER TABLE yapılacak)

// -----------------------------------------------------------------------------
// Çoklu Lokasyon / Şube Desteği
// -----------------------------------------------------------------------------

model Location {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   @db.VarChar(255)
  address     String?  @db.Text
  city        String?  @db.VarChar(100)
  phone       String?  @db.VarChar(50)
  email       String?  @db.VarChar(255)
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceOrders ServiceOrder[]
  appointments  Appointment[]
  parts         Part[]         @relation("PartLocation")
  stockCounts   StockCount[]
  transfersFrom StockTransfer[] @relation("TransferFrom")
  transfersTo   StockTransfer[] @relation("TransferTo")
  stockMovements StockMovement[] @relation("MovementLocation")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// -----------------------------------------------------------------------------
// Mesajlaşma Sistemi (Müşteri ↔ Usta)
// -----------------------------------------------------------------------------

model Message {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  serviceOrderId  String?
  serviceOrder    ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  
  // Gönderici
  customerId      String?
  customer        Customer? @relation("CustomerSentMessages", fields: [customerId], references: [id], onDelete: SetNull)
  
  senderType      String   @db.VarChar(20) // "CUSTOMER" | "MECHANIC" | "ADMIN"
  senderName      String   @db.VarChar(255)
  
  // Alıcı (opsiyonel, broadcast durumunda null)
  receiverId      String?  @db.VarChar(255)
  receiverType    String?  @db.VarChar(20)
  
  content         String   @db.Text
  messageType     String   @default("TEXT") @db.VarChar(20) // "TEXT" | "SYSTEM" | "IMAGE"
  isRead          Boolean  @default(false)
  
  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([serviceOrderId])
  @@index([customerId])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Bakım Planları (MaintenancePlan)
// -----------------------------------------------------------------------------

model MaintenancePlan {
  id          String    @id @default(uuid())
  tenantId    String
  vehicleId   String
  title       String    @db.VarChar(255)
  dueDate     DateTime? @db.Date
  dueMileage  Int?
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([vehicleId])
}

// -----------------------------------------------------------------------------
// Servis Değerlendirmeleri (ServiceRating)
// -----------------------------------------------------------------------------

model ServiceRating {
  id             String   @id @default(uuid())
  tenantId       String
  serviceOrderId String   @unique
  customerId     String
  rating         Int      // 1-5
  comment        String?  @db.Text
  createdAt      DateTime @default(now())

  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  customer       Customer     @relation(fields: [customerId], references: [id])

  @@index([tenantId])
  @@index([serviceOrderId])
}

// -----------------------------------------------------------------------------
// Muhasebe Entegrasyonu
// -----------------------------------------------------------------------------

model AccountingIntegration {
  id           String   @id @default(uuid())
  tenantId     String   @unique
  provider     String   @default("PARASUT") @db.VarChar(50)
  clientId     String   @db.VarChar(255)
  clientSecret String   @db.VarChar(255)
  username     String   @db.VarChar(255)
  password     String   @db.VarChar(255)
  companyId    String   @db.VarChar(100)
  isActive     Boolean  @default(true)
  settings     Json?    @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// Bildirim ve İletişim Sağlayıcıları
// -----------------------------------------------------------------------------

model NotificationProvider {
  id        String   @id @default(uuid())
  tenantId  String
  type      String   @db.VarChar(50) // "SMS", "WHATSAPP", "PUSH"
  provider  String   @db.VarChar(50) // "TWILIO", "NETGSM", "ILETI_MERKEZI" vs.
  isActive  Boolean  @default(true)
  settings  Json?    @default("{}") // Kimlik bilgileri (apiKey, senderId vs.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, provider])
  @@index([tenantId])
}

// -----------------------------------------------------------------------------
// Fatura, Ödeme ve Muhasebe Entegrasyonu - Yeni Modeller
// -----------------------------------------------------------------------------

// e-Fatura enum'ları
enum EInvoiceStatus {
  PENDING
  SENT
  ACCEPTED
  REJECTED
  CANCELLED
}

enum EInvoiceDocType {
  E_INVOICE
  E_ARCHIVE
}

// Fatura kalemi türü
enum InvoiceItemType {
  LABOR
  PART
  SERVICE
}

model InvoiceItem {
  id           String          @id @default(uuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId    String
  invoice      Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type         InvoiceItemType @default(SERVICE)
  name         String          @db.VarChar(255)
  description  String?         @db.Text
  quantity     Decimal         @db.Decimal(10, 2)
  unitPrice    Decimal         @db.Decimal(15, 2)
  taxRate      Decimal         @default(20) @db.Decimal(5, 2)
  discountRate Decimal         @default(0) @db.Decimal(5, 2)
  lineTotal    Decimal         @db.Decimal(15, 2)
  sortOrder    Int             @default(0)
  serviceItemId String?        @db.VarChar(255)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([tenantId])
  @@index([invoiceId])
  @@index([type])
}

// Çek/Senet durumu
enum CheckPaymentStatus {
  PENDING
  COLLECTED
  BOUNCED
}

model CheckPayment {
  id           String             @id @default(uuid())
  tenantId     String
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentId    String             @unique
  payment      Payment            @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  checkNumber  String             @db.VarChar(100)
  bankName     String             @db.VarChar(255)
  dueDate      DateTime           @db.Date
  drawerName   String             @db.VarChar(255)
  status       CheckPaymentStatus @default(PENDING)
  collectedAt  DateTime?
  bouncedAt    DateTime?
  notes        String?            @db.Text
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([tenantId])
  @@index([dueDate])
  @@index([status])
}

model PaymentAttempt {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  provider      String   @db.VarChar(50)
  amount        Decimal  @db.Decimal(15, 2)
  errorCode     String?  @db.VarChar(100)
  errorMessage  String?  @db.Text
  rawResponse   Json?    @default("{}")
  attemptedAt   DateTime @default(now())

  @@index([tenantId])
  @@index([invoiceId])
  @@index([attemptedAt])
}

enum ParasutSyncStatus {
  SUCCESS
  FAILED
}

model ParasutSyncLog {
  id           String            @id @default(uuid())
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId    String?
  invoice      Invoice?          @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  paymentId    String?
  payment      Payment?          @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  operation    String            @db.VarChar(50)
  status       ParasutSyncStatus
  errorMessage String?           @db.Text
  attemptedAt  DateTime          @default(now())

  @@index([tenantId])
  @@index([invoiceId])
  @@index([status])
  @@index([attemptedAt])
}

model InvoiceSequence {
  id        String @id @default(uuid())
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  year      Int
  lastSeq   Int    @default(0)

  @@unique([tenantId, year])
  @@index([tenantId])
}

// -----------------------------------------------------------------------------
// WhatsApp ve Gelişmiş Bildirim Sistemi — Yeni Modeller
// -----------------------------------------------------------------------------

// Tenant bazlı özelleştirilebilir bildirim şablonları
model NotificationTemplate {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type         String    @db.VarChar(50)   // "SERVICE_STATUS" | "APPROVAL" | "APPOINTMENT" | "QUOTE" | "REMINDER" | "BULK"
  channel      String    @db.VarChar(20)   // "SMS" | "WHATSAPP" | "EMAIL"
  name         String    @db.VarChar(255)
  body         String    @db.Text
  variables    String[]                    // Tespit edilen değişken listesi (otomatik)

  // Meta Cloud API HSM alanları
  templateName String?   @db.VarChar(255)
  languageCode String?   @db.VarChar(10)

  isActive     Boolean   @default(true)
  isDefault    Boolean   @default(false)

  notifications Notification[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@unique([tenantId, type, channel])
  @@index([tenantId])
  @@index([type])
}

// Müşteri bildirim kanalı tercihleri
model CustomerNotificationPreference {
  id               String    @id @default(uuid())
  tenantId         String
  customerId       String    @unique

  smsEnabled       Boolean   @default(true)
  whatsappEnabled  Boolean   @default(false)
  emailEnabled     Boolean   @default(true)
  preferredChannel String    @default("SMS") @db.VarChar(20)

  // IYS (İleti Yönetim Sistemi) pazarlama izin alanları
  marketingConsentGivenAt   DateTime?
  marketingConsentRevokedAt DateTime?
  iysConsentId              String?   @db.VarChar(100)
  iysLastSyncAt             DateTime?

  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantId, customerId])
  @@index([tenantId])
  @@index([customerId])
}

// Toplu bildirim kampanyaları
model BulkNotificationCampaign {
  id              String    @id @default(uuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name            String    @db.VarChar(255)
  channel         String    @db.VarChar(20)
  messageBody     String    @db.Text

  segmentType     String    @db.VarChar(50)
  segmentParams   Json?     @default("{}")

  totalCount      Int       @default(0)
  sentCount       Int       @default(0)
  failedCount     Int       @default(0)
  skippedCount    Int       @default(0)

  status          String    @default("DRAFT") @db.VarChar(20)
  startedAt       DateTime?
  completedAt     DateTime?

  createdById     String?
  notifications   Notification[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// KVKK Uyumu
// -----------------------------------------------------------------------------

// KVKK açık rıza kayıtları
model KvkkConsent {
  id           String    @id @default(uuid())
  tenantId     String
  customerId   String?
  userId       String?

  // "REGISTRATION" | "APPOINTMENT" | "MARKETING" | "SERVICE"
  consentType  String    @db.VarChar(50)
  ipAddress    String?   @db.VarChar(50)
  userAgent    String?   @db.Text
  givenAt      DateTime  @default(now())
  revokedAt    DateTime?
  // Metni güncellendiğinde version takibi
  version      String    @default("1.0") @db.VarChar(10)

  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([customerId])
  @@index([consentType])
}

// Veri sahibi hakkı talepleri (KVKK Madde 11)
model DataSubjectRequest {
  id          String    @id @default(uuid())
  tenantId    String
  customerId  String?

  // "ERASURE" | "EXPORT" | "ACCESS" | "CORRECTION" | "OBJECTION"
  requestType String    @db.VarChar(50)
  // "PENDING" | "IN_PROGRESS" | "COMPLETED" | "REJECTED"
  status      String    @default("PENDING") @db.VarChar(20)
  notes       String?   @db.Text
  processedAt DateTime?
  processedBy String?   @db.VarChar(255)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@index([customerId])
}
