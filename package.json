{
  "name": "bst-otoservis",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.21",
    "typescript": "5.9.2",
    "vercel": "^54.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "swagger-ui-react>react": "19",
        "swagger-ui-react>react-dom": "19",
        "react-copy-to-clipboard>react": "19",
        "react-debounce-input>react": "19",
        "react-inspector>react": "19"
      }
    }
  }
}
