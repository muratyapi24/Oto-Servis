{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "NODE_ENV",
        "NEXTAUTH_URL",
        "NEXTAUTH_SECRET",
        "NEXT_RUNTIME",
        "DATABASE_URL",
        "DIRECT_URL",
        "ADMIN_EMAIL",
        "AWS_ACCESS_KEY_ID",
        "AWS_REGION",
        "AWS_S3_BUCKET",
        "AWS_SECRET_ACCESS_KEY",
        "DEMO_EMAIL",
        "DEMO_PASSWORD",
        "DEMO_TENANT_SLUG",
        "EMAIL_FROM",
        "ENABLE_SUPER_ADMIN_PREVIEW",
        "E_INVOICE_INTEGRATOR_URL",
        "E_INVOICE_PASSWORD",
        "E_INVOICE_USERNAME",
        "INNGEST_EVENT_KEY",
        "INNGEST_SIGNING_KEY",
        "IYZICO_API_KEY",
        "IYZICO_BASE_URL",
        "IYZICO_SECRET_KEY",
        "MEILISEARCH_API_KEY",
        "MEILISEARCH_HOST",
        "META_WHATSAPP_ACCESS_TOKEN",
        "META_WHATSAPP_PHONE_NUMBER_ID",
        "META_WHATSAPP_WEBHOOK_SECRET",
        "NOTIFICATION_ENCRYPTION_KEY",
        "PAYTR_MERCHANT_ID",
        "PAYTR_MERCHANT_KEY",
        "PAYTR_MERCHANT_SALT",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "SENTRY_DSN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_AUTH_TOKEN",
        "STRIPE_PUBLISHABLE_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "TWILIO_ACCOUNT_SID",
        "TWILIO_AUTH_TOKEN",
        "TWILIO_PHONE_NUMBER",
        "TWILIO_WHATSAPP_NUMBER",
        "UPSTASH_REDIS_REST_TOKEN",
        "UPSTASH_REDIS_REST_URL",
        "VAPID_PRIVATE_KEY",
        "VAPID_PUBLIC_KEY",
        "VAPID_SUBJECT",
        "npm_package_version"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
