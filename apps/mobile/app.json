{
  "expo": {
    "name": "MS Oto Servis",
    "slug": "bst-oto-servis",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bstoto.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Servis fotoğrafı çekmek için kamera erişimi gereklidir.",
        "NSFaceIDUsageDescription": "Güvenli giriş için Face ID kullanılır."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e40af"
      },
      "package": "com.bstoto.mobile",
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Servis fotoğrafı çekmek için kamera erişimi gereklidir."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1e40af"
        }
      ]
    ],
    "scheme": "bstoto",
    "extra": {
      "eas": {
        "projectId": "bst-oto-servis"
      }
    }
  }
}